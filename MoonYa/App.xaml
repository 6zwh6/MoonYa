<Application x:Class="MoonYa.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- ── Title-bar (white / light) ──────────── -->
            <Color x:Key="TitleBarBg">#FFFFFF</Color>
            <Color x:Key="TitleBarText">#1A1A1A</Color>
            <Color x:Key="TitleBarSubText">#6B6B6B</Color>
            <Color x:Key="TitleBarBtnHover">#E6E6E6</Color>
            <Color x:Key="TitleBarBtnCloseHover">#C42B1C</Color>

            <!-- ── Loading / main area (light) ─────────── -->
            <Color x:Key="BgDark">#FFFFFF</Color>
            <Color x:Key="BgMid">#F5F5F5</Color>
            <Color x:Key="BgSurface">#EEEEEE</Color>
            <Color x:Key="BgElevated">#E8E8E8</Color>
            <Color x:Key="BorderSubtle">#E0E0E0</Color>
            <Color x:Key="BorderDefault">#D1D1D1</Color>
            <Color x:Key="TextPrimary">#1A1A1A</Color>
            <Color x:Key="TextSecondary">#6B6B6B</Color>
            <Color x:Key="TextMuted">#9A9A9A</Color>
            <Color x:Key="AccentWarm">#C8965A</Color>
            <Color x:Key="AccentWarmHover">#D4A86C</Color>
            <Color x:Key="AccentGreen">#5B9A6B</Color>
            <Color x:Key="AccentRed">#C85050</Color>
            <Color x:Key="AccentAmber">#D4943C</Color>

            <!-- ── Brushes ─────────────────────────────── -->
            <SolidColorBrush x:Key="BrushTitleBarBg" Color="{StaticResource TitleBarBg}" />
            <SolidColorBrush x:Key="BrushTitleBarText" Color="{StaticResource TitleBarText}" />
            <SolidColorBrush x:Key="BrushTitleBarSubText" Color="{StaticResource TitleBarSubText}" />
            <SolidColorBrush x:Key="BrushTitleBarBtnHover" Color="{StaticResource TitleBarBtnHover}" />
            <SolidColorBrush x:Key="BrushBgDark" Color="{StaticResource BgDark}" />
            <SolidColorBrush x:Key="BrushBgMid" Color="{StaticResource BgMid}" />
            <SolidColorBrush x:Key="BrushBgSurface" Color="{StaticResource BgSurface}" />
            <SolidColorBrush x:Key="BrushBgElevated" Color="{StaticResource BgElevated}" />
            <SolidColorBrush x:Key="BrushBorderSubtle" Color="{StaticResource BorderSubtle}" />
            <SolidColorBrush x:Key="BrushBorderDefault" Color="{StaticResource BorderDefault}" />
            <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource TextPrimary}" />
            <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource TextMuted}" />
            <SolidColorBrush x:Key="BrushAccentWarm" Color="{StaticResource AccentWarm}" />
            <SolidColorBrush x:Key="BrushAccentGreen" Color="{StaticResource AccentGreen}" />

            <!-- ── Global Styles ───────────────────────── -->
            <Style TargetType="Window" x:Key="MainWindowStyle">
                <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Variable, system-ui, sans-serif" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="UseLayoutRounding" Value="True" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
                <Setter Property="TextOptions.TextRenderingMode" Value="Auto" />
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Variable, system-ui, sans-serif" />
            </Style>

            <Style x:Key="StatusText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Variable, system-ui, sans-serif" />
            </Style>

            <Style x:Key="LoadingText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Variable, system-ui, sans-serif" />
            </Style>

            <Style x:Key="TitleBarTitleText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource BrushTitleBarText}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Variable, system-ui, sans-serif" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
