<Window x:Class="MoonYa.PetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FurinaPet"
        Width="190" Height="270"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        AllowDrop="True"
        DragEnter="OnFileDragEnter"
        DragOver="OnFileDragOver"
        DragLeave="OnFileDragLeave"
        Drop="OnFileDrop"
        TextOptions.TextFormattingMode="Ideal">

    <Window.Resources>
        <!-- 芙宁娜主题色 -->
        <SolidColorBrush x:Key="FuriBlue" Color="#4A9EFF" />
        <SolidColorBrush x:Key="FuriDeep" Color="#1A4FA3" />
        <SolidColorBrush x:Key="FuriCyan" Color="#7FD4FF" />
        <SolidColorBrush x:Key="FuriGold" Color="#FFD76B" />
        <SolidColorBrush x:Key="FuriWhite" Color="#FFFFFF" />
        <SolidColorBrush x:Key="FuriDanger" Color="#D4453A" />

        <!-- 聊天气泡样式 -->
        <Style x:Key="ChatBubble" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource FuriCyan}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MaxWidth" Value="240" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#4A9EFF" BlurRadius="14" ShadowDepth="2" Opacity="0.5" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 右键菜单容器样式（芙宁娜风格 + 纵向滚动） -->
        <Style x:Key="FuriContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="#F2F8FF" />
            <Setter Property="BorderBrush" Value="{StaticResource FuriCyan}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="MaxWidth" Value="190" />
            <Setter Property="MaxHeight" Value="320" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#1A4FA3" BlurRadius="16" ShadowDepth="4" Opacity="0.35" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="4">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="True"
                                          MaxHeight="{TemplateBinding MaxHeight}">
                                <StackPanel IsItemsHost="True" />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 菜单阴影资源 -->
        <DropShadowEffect x:Key="FuriMenuShadow" Color="#1A4FA3" BlurRadius="16" ShadowDepth="4" Opacity="0.35" />

        <!-- 滑条填充渐变（深青 → 芙蓝 → 浅蓝） -->
        <LinearGradientBrush x:Key="FuriSliderFillBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#1A4FA3" Offset="0" />
            <GradientStop Color="#4A9EFF" Offset="0.55" />
            <GradientStop Color="#7FD4FF" Offset="1" />
        </LinearGradientBrush>

        <!-- 滑条空白侧按钮（透明，仅占位响应点击） -->
        <Style x:Key="FuriSliderGhostRepeat" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 滑条已填充侧按钮（渐变轨道，随滑钮伸缩） -->
        <Style x:Key="FuriSliderFillRepeat" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="6"
                                VerticalAlignment="Center"
                                CornerRadius="3,0,0,3"
                                Background="{StaticResource FuriSliderFillBrush}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 芙宁娜风格滑钮（白珠 + 蓝环 + 金心 + 辉光，悬停放大） -->
        <Style x:Key="FuriSliderThumb" TargetType="Thumb">
            <Setter Property="Width" Value="17" />
            <Setter Property="Height" Value="17" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid>
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="ThumbScale" ScaleX="1" ScaleY="1" />
                            </Grid.RenderTransform>
                            <Ellipse Fill="#FFFFFF"
                                     Stroke="{StaticResource FuriBlue}"
                                     StrokeThickness="2.5">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#4A9EFF" BlurRadius="8" ShadowDepth="0" Opacity="0.55" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <Ellipse Width="5" Height="5" Fill="{StaticResource FuriGold}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbScale" Storyboard.TargetProperty="ScaleX" To="1.25" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="ThumbScale" Storyboard.TargetProperty="ScaleY" To="1.25" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.18" />
                                            <DoubleAnimation Storyboard.TargetName="ThumbScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 芙宁娜风格滑条（圆角轨道 + 渐变填充 + 点击跳格） -->
        <Style x:Key="FuriSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="80" />
            <Setter Property="Maximum" Value="600" />
            <Setter Property="TickFrequency" Value="10" />
            <Setter Property="IsSnapToTickEnabled" Value="True" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="Height" Value="20" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Foreground" Value="{StaticResource FuriBlue}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid SnapsToDevicePixels="True">
                            <Border Height="6"
                                    VerticalAlignment="Center"
                                    CornerRadius="3"
                                    Background="#DCEBFF">
                                <Border.Effect>
                                    <DropShadowEffect Color="#1A4FA3" BlurRadius="2" ShadowDepth="0.5" Opacity="0.12" />
                                </Border.Effect>
                            </Border>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource FuriSliderFillRepeat}" Command="{x:Static Slider.DecreaseLarge}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource FuriSliderThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource FuriSliderGhostRepeat}" Command="{x:Static Slider.IncreaseLarge}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 菜单项样式（支持二级菜单 Popup） -->
        <Style x:Key="FuriMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#1A4FA3" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  TextBlock.Foreground="{TemplateBinding Foreground}" />
                                <Path x:Name="Arrow"
                                      Grid.Column="1"
                                      Data="M 0,0 L 4,4 L 0,8 Z"
                                      Fill="#1A4FA3"
                                      Margin="8,0,0,0"
                                      Visibility="Collapsed" />
                                <!-- 二级菜单 Popup -->
                                <Popup x:Name="SubMenuPopup"
                                       Grid.Column="0"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Right"
                                       HorizontalOffset="-4"
                                       VerticalOffset="-6"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Fade">
                                    <Border Background="#F2F8FF"
                                            BorderBrush="{StaticResource FuriCyan}"
                                            BorderThickness="1.5"
                                            CornerRadius="14"
                                            Padding="4"
                                            Margin="6"
                                            Effect="{StaticResource FuriMenuShadow}">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      CanContentScroll="True"
                                                      MaxHeight="320">
                                            <StackPanel IsItemsHost="True" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E4A9EFF" />
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="SubMenuPopup" Property="Placement" Value="Bottom" />
                                <Setter TargetName="SubMenuPopup" Property="HorizontalOffset" Value="0" />
                                <Setter TargetName="SubMenuPopup" Property="VerticalOffset" Value="0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 聊天气泡（不参与桌宠姿态变换，保持稳定） -->
        <Border x:Name="BubbleBorder"
                Grid.Row="0"
                Style="{StaticResource ChatBubble}"
                Background="#FFFFFF"
                Visibility="Collapsed"
                HorizontalAlignment="Center"
                Margin="0,0,0,8"
                Opacity="0">
            <StackPanel>
                <TextBlock x:Name="BubbleText"
                           TextWrapping="Wrap"
                           FontSize="13"
                           FontWeight="Medium"
                           Foreground="#1A4FA3"
                           TextAlignment="Center" />
            <!-- 气泡小尾巴 -->
                <Path Data="M 0,0 L 8,0 L 4,7 Z"
                      Fill="#7FD4FF"
                      HorizontalAlignment="Center"
                      Margin="0,2,0,-6" />
            </StackPanel>
        </Border>

        <!-- 桌宠分层立绘（941x1672 等比盒；骨骼层：腿/身/手/头/眼睑/嘴） -->
        <Grid x:Name="PetCanvas"
              Grid.Row="1"
              Width="112.6"
              Height="200"
              HorizontalAlignment="Center"
              VerticalAlignment="Bottom"
              RenderTransformOrigin="0.5,1"
              UseLayoutRounding="True"
              SnapsToDevicePixels="True">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="PetScale" ScaleX="1" ScaleY="1" />
                    <ScaleTransform x:Name="PetTurnScale" ScaleX="1" ScaleY="1" />
                    <SkewTransform x:Name="PetSkew" AngleX="0" />
                    <RotateTransform x:Name="PetRotate" Angle="0" />
                    <TranslateTransform x:Name="PetTranslate" X="0" Y="0" />
                    <ScaleTransform x:Name="SpriteFlip" ScaleX="1" ScaleY="1" />
                </TransformGroup>
            </Grid.RenderTransform>
            <Grid.Effect>
                <DropShadowEffect Color="#1A4FA3" BlurRadius="8" ShadowDepth="3" Opacity="0.25" />
            </Grid.Effect>

            <!-- 身体+长裙+四肢+长头发（整图仅挖头，零切割痕迹） -->
            <Image x:Name="BaseImg"
                   Source="pack://application:,,,/Assets/pet_base.png"
                   Stretch="Fill" />
            <!-- 头部（颈部支点 480,732） -->
            <Image x:Name="HeadImg"
                   Source="pack://application:,,,/Assets/pet_head.png"
                   Stretch="Fill" RenderTransformOrigin="0.5101,0.4378">
                <Image.RenderTransform>
                    <RotateTransform x:Name="HeadRotate" Angle="0" />
                </Image.RenderTransform>
            </Image>
            <!-- 散步侧身全身（脚底支点；左右两张帧图按移动方向切换） -->
            <Image x:Name="SideImg"
                   Source="pack://application:,,,/Assets/pet_side_r.png"
                   Stretch="Fill"
                   Visibility="Collapsed"
                   RenderTransformOrigin="0.5,0.91">
                <Image.RenderTransform>
                    <RotateTransform x:Name="SideRotate" Angle="0" />
                </Image.RenderTransform>
            </Image>
        </Grid>
    </Grid>

    <Window.ContextMenu>
        <ContextMenu x:Name="PetContextMenu" Style="{StaticResource FuriContextMenu}">
            <MenuItem Header="芙宁娜·菜单" IsEnabled="False" FontWeight="Bold" />
            <Separator Background="#3F4A9EFF" Margin="6,2" />
            <MenuItem x:Name="StrollMenuItem"
                      Header="散步模式"
                      IsCheckable="True"
                      Style="{StaticResource FuriMenuItem}" />
            <Separator Background="#3F4A9EFF" Margin="6,2" />
            <MenuItem x:Name="ResizeMenuItem"
                      Header="自定义尺寸"
                      Style="{StaticResource FuriMenuItem}">
                <MenuItem Style="{StaticResource FuriMenuItem}" StaysOpenOnClick="True" Padding="10,7" Cursor="Arrow">
                    <MenuItem.Header>
                        <StackPanel Width="158">
                            <Grid Margin="3,0,3,4">
                                <TextBlock Text="拖动调整尺寸"
                                           FontSize="11"
                                           Foreground="#7E97C2"
                                           VerticalAlignment="Center" />
                                <TextBlock HorizontalAlignment="Right"
                                           FontSize="11.5"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource FuriDeep}">
                                    <TextBlock.Text>
                                        <Binding ElementName="SizeSlider" Path="Value" StringFormat="{}{0:F0} px" />
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <Slider x:Name="SizeSlider" Style="{StaticResource FuriSlider}" />
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <Separator Background="#3F4A9EFF" Margin="6,2" />
                <MenuItem x:Name="SizeSmallItem" Header="小 (120px)" Style="{StaticResource FuriMenuItem}" />
                <MenuItem x:Name="SizeMediumItem" Header="中 (200px)" Style="{StaticResource FuriMenuItem}" />
                <MenuItem x:Name="SizeLargeItem" Header="大 (280px)" Style="{StaticResource FuriMenuItem}" />
                <MenuItem x:Name="SizeHugeItem" Header="巨 (400px)" Style="{StaticResource FuriMenuItem}" />
            </MenuItem>
            <Separator Background="#3F4A9EFF" Margin="6,2" />
            <MenuItem x:Name="CloseMenuItem"
                      Header="关闭桌宠"
                      Foreground="#D4453A"
                      Style="{StaticResource FuriMenuItem}" />
        </ContextMenu>
    </Window.ContextMenu>
</Window>
