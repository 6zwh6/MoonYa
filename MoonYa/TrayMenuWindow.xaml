<Window x:Class="MoonYa.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrayMenu"
        Width="160" Height="Auto"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <Style x:Key="TrayMenuItemStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#1A1A1A" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Variable, Microsoft YaHei, system-ui, sans-serif" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,0,16,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="4,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F0F0F0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E5E5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White"
            CornerRadius="8"
            Padding="0,4,0,6"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect Color="#20000000"
                              BlurRadius="16"
                              ShadowDepth="2"
                              Direction="270"
                              Opacity="0.6" />
        </Border.Effect>

        <StackPanel>
            <!-- 显示MoonYa -->
            <Button x:Name="ShowBtn"
                    Click="ShowBtn_Click"
                    Style="{StaticResource TrayMenuItemStyle}"
                    Content="显示MoonYa" />

            <!-- 分隔线：浅黑色、左右12px间距、两端渐变透明 -->
            <Grid Height="1" Margin="12,0">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="Transparent" Offset="0" />
                        <GradientStop Color="#E0E0E0" Offset="0.12" />
                        <GradientStop Color="#E0E0E0" Offset="0.88" />
                        <GradientStop Color="Transparent" Offset="1" />
                    </LinearGradientBrush>
                </Grid.Background>
            </Grid>

            <!-- 退出MoonYa -->
            <Button x:Name="ExitBtn"
                    Click="ExitBtn_Click"
                    Style="{StaticResource TrayMenuItemStyle}"
                    Content="退出MoonYa" />
        </StackPanel>
    </Border>
</Window>
