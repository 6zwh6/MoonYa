<Window x:Class="MoonYa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MoonYa"
        xmlns:cef="clr-namespace:CefSharp.Wpf;assembly=CefSharp.Wpf"
        Title="MoonYa"
        Width="1280" Height="820"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MainWindowStyle}"
        WindowStyle="None"
        Background="Transparent"
        ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1"
                      CornerRadius="8"
                      ResizeBorderThickness="6"
                      CaptionHeight="32" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- ── Title-bar button style (light) ────── -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E6E6E6" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B1C" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  ROOT LAYOUT                                         -->
    <!-- ══════════════════════════════════════════════════════ -->
    <Border x:Name="RootBorder"
            Background="{StaticResource BrushBgDark}"
            CornerRadius="8"
            BorderBrush="#D1D1D1"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── TITLE BAR (white) ──────────────────────── -->
            <Grid x:Name="TitleBarGrid"
                  Grid.Row="0"
                  Background="{StaticResource BrushTitleBarBg}"
                  Visibility="Collapsed"
                  Height="32"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- App icon + title + refresh -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="14,0,0,0">
                    <Image Source="yax_rounded.ico"
                           Width="18" Height="18"
                           VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock Text="MoonYa"
                               Style="{StaticResource TitleBarTitleText}"
                               VerticalAlignment="Center" />
                    <!-- Refresh button -->
                    <Button Width="28" Height="28" Margin="8,0,0,0"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" FocusVisualStyle="{x:Null}"
                            Click="Refresh_Click" ToolTip="刷新页面"
                            VerticalAlignment="Center">
                        <Canvas Width="14" Height="14">
                            <Path Stroke="#1A1A1A" StrokeThickness="1.3"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Data="M 7,2 A 5,5 0 1,1 4,11" />
                            <Path Stroke="#1A1A1A" StrokeThickness="1.3"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Data="M 7,2 L 9,0 L 9,4 Z" />
                        </Canvas>
                    </Button>
                </StackPanel>

                <!-- Window controls — vector-drawn icons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- Minimize -->
                    <Button Style="{StaticResource TitleBarButton}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="Minimize_Click" ToolTip="最小化">
                        <Canvas Width="10" Height="10">
                            <Line X1="1" Y1="7" X2="9" Y2="7"
                                  Stroke="#1A1A1A" StrokeThickness="1.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Canvas>
                    </Button>

                    <!-- Maximize / Restore -->
                    <Button x:Name="MaxRestoreBtn"
                            Style="{StaticResource TitleBarButton}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MaximizeRestore_Click" ToolTip="最大化">
                        <Grid Width="10" Height="10">
                            <!-- Maximize: single square -->
                            <Canvas x:Name="MaxCanvas" Visibility="Visible">
                                <Rectangle Width="8" Height="8"
                                           Canvas.Left="1" Canvas.Top="1"
                                           Stroke="#1A1A1A" StrokeThickness="1.2"
                                           Fill="Transparent" />
                            </Canvas>
                            <!-- Restore: two overlapping squares -->
                            <Canvas x:Name="RestoreCanvas" Visibility="Collapsed">
                                <Rectangle Width="6" Height="6"
                                           Canvas.Left="3" Canvas.Top="1"
                                           Stroke="#1A1A1A" StrokeThickness="1.2"
                                           Fill="Transparent" />
                                <Rectangle Width="6" Height="6"
                                           Canvas.Left="1" Canvas.Top="3"
                                           Stroke="#1A1A1A" StrokeThickness="1.2"
                                           Fill="#FFFFFF" />
                            </Canvas>
                        </Grid>
                    </Button>

                    <!-- Close -->
                    <Button Style="{StaticResource CloseButton}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="Close_Click" ToolTip="关闭"
                            MouseEnter="CloseBtn_MouseEnter"
                            MouseLeave="CloseBtn_MouseLeave">
                        <Canvas Width="10" Height="10">
                            <Line x:Name="CloseLine1" X1="1" Y1="1" X2="9" Y2="9"
                                  Stroke="#1A1A1A" StrokeThickness="1.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            <Line x:Name="CloseLine2" X1="9" Y1="1" X2="1" Y2="9"
                                  Stroke="#1A1A1A" StrokeThickness="1.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Canvas>
                    </Button>
                </StackPanel>

            </Grid>

            <!-- ── WEBVIEW AREA ───────────────────────────── -->
            <Grid Grid.Row="1" Background="{StaticResource BrushBgDark}">
                <local:CustomChromiumWebBrowser x:Name="WebView"
                                        Focusable="True"
                                        IsTabStop="True"
                                        KeyboardNavigation.TabNavigation="Once"
                                        KeyboardNavigation.DirectionalNavigation="Cycle"
                                        GotFocus="WebView_GotFocus"
                                        LostFocus="WebView_LostFocus"
                                        PreviewMouseDown="WebView_PreviewMouseDown"
                                        PreviewMouseUp="WebView_PreviewMouseUp" />

                <!-- ── LOADING OVERLAY ────────────────────── -->
                <Grid x:Name="LoadingOverlay"
                      Background="{StaticResource BrushBgDark}"
                      Visibility="Visible">

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextBlock.TextAlignment="Center">

                        <TextBlock Text="MoonYa"
                                   FontSize="32"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   FontFamily="Segoe UI, Segoe UI Variable, system-ui, sans-serif"
                                   Margin="0,0,0,28" />

                        <!-- Rounded black progress bar -->
                        <ProgressBar x:Name="LoadingProgressBar"
                                     IsIndeterminate="True"
                                     Width="280"
                                     Height="6"
                                     Margin="0,0,0,32">
                            <ProgressBar.Style>
                                <Style TargetType="ProgressBar">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ProgressBar">
                                                <Grid>
                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="CommonStates">
                                                            <VisualState x:Name="Determinate" />
                                                            <VisualState x:Name="Indeterminate">
                                                                <Storyboard RepeatBehavior="Forever">
                                                                    <!-- Position: 0 → 160 → 0 -->
                                                                    <DoubleAnimationUsingKeyFrames
                                                                        Storyboard.TargetName="PART_Indicator"
                                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
                                                                        <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="160">
                                                                            <EasingDoubleKeyFrame.EasingFunction>
                                                                                <CubicEase EasingMode="EaseInOut" />
                                                                            </EasingDoubleKeyFrame.EasingFunction>
                                                                        </EasingDoubleKeyFrame>
                                                                        <EasingDoubleKeyFrame KeyTime="0:0:1.6" Value="0">
                                                                            <EasingDoubleKeyFrame.EasingFunction>
                                                                                <CubicEase EasingMode="EaseInOut" />
                                                                            </EasingDoubleKeyFrame.EasingFunction>
                                                                        </EasingDoubleKeyFrame>
                                                                    </DoubleAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </VisualState>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                    <Border Background="#E0E0E0"
                                                            CornerRadius="4"
                                                            BorderThickness="0"
                                                            ClipToBounds="True" />
                                                    <Border x:Name="PART_Indicator"
                                                            CornerRadius="4"
                                                            HorizontalAlignment="Left"
                                                            Width="120"
                                                            RenderTransformOrigin="0,0.5">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="Transparent" Offset="0.0" />
                                                                <GradientStop Color="#4D1A1A1A" Offset="0.25" />
                                                                <GradientStop Color="#1A1A1A" Offset="0.5" />
                                                                <GradientStop Color="#4D1A1A1A" Offset="0.75" />
                                                                <GradientStop Color="Transparent" Offset="1.0" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Border.RenderTransform>
                                                            <TranslateTransform />
                                                        </Border.RenderTransform>
                                                    </Border>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ProgressBar.Style>
                        </ProgressBar>
                        <TextBlock Text="正在启动MoonYa"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontFamily="Segoe UI, Segoe UI Variable, system-ui, sans-serif"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
